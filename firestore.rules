rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== ヘルパー関数 =====
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }
    function isAdmin() {
      // TODO: 管理者メールを設定。複数人の場合は in [...] に
      return isAuth() && request.auth.token.email in [
        'spice.matching@gmail.com'
      ];
    }
    function notChanged(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // ===== users =====
    // 公開プロフィール。認証済みなら読み取り。
    // 本人は ageVerificationStatus を 'approved'/'rejected' に変更不可（管理者のみ）
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId);
      allow update: if isAdmin()
                    || (isOwner(userId)
                        && (!('userId' in request.resource.data) || request.resource.data.userId == userId)
                        && (!('ageVerificationStatus' in request.resource.data)
                            || request.resource.data.ageVerificationStatus in ['not_submitted', 'pending']
                            || request.resource.data.ageVerificationStatus == resource.data.ageVerificationStatus));
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ===== usersPrivate =====
    // 機密情報（メール・身分証画像URL等）。本人と管理者のみアクセス可。
    match /usersPrivate/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // ===== stories =====
    // 自分の投稿のみ作成、更新時は userId 不変
    match /stories/{storyId} {
      allow read: if isAuth();
      allow create: if isAuth()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth()
                    && resource.data.userId == request.auth.uid
                    && notChanged('userId');
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ===== likes =====
    match /likes/{likeId} {
      allow read: if isAuth();
      allow create: if isAuth()
                    && request.resource.data.fromUserId == request.auth.uid;
      allow update: if isAuth()
                    && resource.data.fromUserId == request.auth.uid
                    && notChanged('fromUserId')
                    && notChanged('toUserId');
      allow delete: if isAuth() && resource.data.fromUserId == request.auth.uid;
    }

    // ===== swipes =====
    match /swipes/{swipeId} {
      allow read: if isAuth();
      allow create: if isAuth()
                    && request.resource.data.fromUserId == request.auth.uid;
      allow update: if isAuth()
                    && resource.data.fromUserId == request.auth.uid
                    && notChanged('fromUserId');
      allow delete: if isAuth() && resource.data.fromUserId == request.auth.uid;
    }

    // ===== matches =====
    // users 配列に自分が含まれる場合のみ作成・更新・削除。users 配列は不変。
    match /matches/{matchId} {
      allow read: if isAuth();
      allow create: if isAuth()
                    && request.auth.uid in request.resource.data.users;
      allow update: if isAuth()
                    && request.auth.uid in resource.data.users
                    && notChanged('users');
      allow delete: if isAuth() && request.auth.uid in resource.data.users;
    }

    // ===== blocks =====
    match /blocks/{blockId} {
      allow read: if isAuth();
      allow create: if isAuth()
                    && request.resource.data.fromUserId == request.auth.uid;
      allow delete: if isAuth() && resource.data.fromUserId == request.auth.uid;
    }

    // ===== reports =====
    // 通報は本人だけ作成可、閲覧は管理者のみ
    match /reports/{reportId} {
      allow read, update, delete: if isAdmin();
      allow create: if isAuth()
                    && request.resource.data.fromUserId == request.auth.uid;
    }

    // ===== admin_notifications =====
    match /admin_notifications/{id} {
      allow read, update, delete: if isAdmin();
      allow create: if isAuth();
    }

    // ===== calls =====
    // 通話は当事者のみ操作可、callerId/receiverId は不変
    match /calls/{callId} {
      allow read: if isAuth();
      allow create: if isAuth()
                    && request.resource.data.callerId == request.auth.uid;
      allow update: if isAuth()
                    && (resource.data.callerId == request.auth.uid
                        || resource.data.receiverId == request.auth.uid)
                    && notChanged('callerId')
                    && notChanged('receiverId');
    }

    // ===== pushTokens =====
    // 認証ユーザーは他人のトークンを閲覧可（プッシュ送信のため）
    // ※将来的には Cloud Functions 経由にして read を isOwner に絞ることを推奨
    match /pushTokens/{userId} {
      allow read: if isAuth();
      allow write: if isOwner(userId);
    }

    // ===== friends =====
    match /friends/{friendId} {
      allow read: if isAuth();
      allow create: if isAuth()
                    && request.resource.data.fromUserId == request.auth.uid;
      allow update: if isAuth()
                    && (resource.data.fromUserId == request.auth.uid
                        || resource.data.toUserId == request.auth.uid)
                    && notChanged('fromUserId')
                    && notChanged('toUserId');
      allow delete: if isAuth()
                    && (resource.data.fromUserId == request.auth.uid
                        || resource.data.toUserId == request.auth.uid);
    }

    // ===== locationShares =====
    match /locationShares/{shareId} {
      allow read: if isAuth();
      allow create: if isAuth()
                    && request.resource.data.fromUserId == request.auth.uid;
      allow update: if isAuth()
                    && resource.data.fromUserId == request.auth.uid
                    && notChanged('fromUserId');
      allow delete: if isAuth() && resource.data.fromUserId == request.auth.uid;
    }

    // ===== それ以外のコレクション: デフォルト拒否 =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
